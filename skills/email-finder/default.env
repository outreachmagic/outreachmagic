# Copy to ~/.hermes/.env (or export in shell). See config.example.json for overrides.

TRYKITT_API_KEY=
ICYPEAS_API_KEY=
MILLIONVERIFIER_API_KEY=

# Optional: set true in config.json to spend ~1 trykitt lookup on pre-batch health check
# trykitt_live_health_probe=false

# Optional — auto-detected at ~/.hermes/skills/outreachmagic/
# OUTREACHMAGIC_HOME=

# Same as outreachmagic — required for save/dedup
OUTREACHMAGIC_AGENT_KEY=
