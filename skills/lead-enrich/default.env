# Lead Enrich — add these lines to ~/.hermes/.env (Hermes secrets file)
# Do not commit real keys. Copy only the variables you need.

# Serper.dev — Google Search API (https://serper.dev)
SERPER_API_KEY=

# Outreach Magic — agent key for pipeline dedup + import-profiles
# Create at https://dev.outreachmagic.io/setup/agent
OUTREACHMAGIC_AGENT_KEY=

# trykitt.ai — optional email find + verify (https://trykitt.ai, free tier)
# Enables Phase 5 in SKILL.md. Free tier: ~10 concurrent max; use 8s+ delay in batches.
TRYKITT_API_KEY=

# Optional — only if outreachmagic is not in ~/.hermes/skills/outreachmagic/
# OUTREACHMAGIC_HOME=
