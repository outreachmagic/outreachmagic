          "--min-confidence", "ALL",
          "--output", "@fixture:dedup/find-output.json"
        ],
        "expect": {
          "contains_json": true,
          "json_stats": [
            "total_leads_scanned",
            "candidates_found",
            "high_confidence",
            "medium_confidence",
            "low_confidence"
          ],
          "json_fields": [
            {"path": "stats.total_leads_scanned", "equals": 13},
            {"path": "stats.candidates_found", "gte": 6}
          ]
        }
      },
